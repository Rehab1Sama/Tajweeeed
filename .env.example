# ─── نور التجويد — Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in the values for local development.
# On Render: set these in the dashboard (Services → Environment tab).
# NEVER commit .env with real secrets to version control.

# ── Server ────────────────────────────────────────────────────────────────────

# Port the API server listens on (Render injects this automatically)
PORT=8080

# Node environment: "development" | "production"
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string
# Local:  postgres://postgres:password@localhost:5432/noor_tajweed
# Render: copied automatically from the linked database
DATABASE_URL=postgres://postgres:password@localhost:5432/noor_tajweed

# ── Clerk Authentication ───────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → Your App → API Keys

# Server-side keys (API server)
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Client-side key (baked into the frontend bundle at build time)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Clerk proxy URL — routes Clerk auth requests through your own domain.
# Required in production for Clerk to work on non-Clerk domains.
# Set to: https://YOUR-RENDER-APP.onrender.com/api/__clerk
# Leave empty for local development (proxy is disabled in dev mode).
VITE_CLERK_PROXY_URL=

# ── App Secrets ───────────────────────────────────────────────────────────────

# Secret used by POST /api/setup/make-teacher to bootstrap the first teacher.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# ── Frontend Build (set these at build time on Render) ─────────────────────────

# Base URL path for the frontend (use "/" for root-mounted deployments)
# On Replit this is set to the artifact preview path.
BASE_PATH=/
